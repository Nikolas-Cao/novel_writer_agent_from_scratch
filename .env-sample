MODEL=model-name
BASE_URL=https://xxx/v1
API_KEY=your-api-key-here

# 章节插图（OpenAI Images API，可选；不配置则生图失败并跳过插图）
# IMAGE_GEN_API_KEY=
# IMAGE_GEN_BASE_URL=
# IMAGE_GEN_MODEL=dall-e-3
# IMAGE_GEN_SIZE=1024x1024
# IMAGE_GEN_TIMEOUT_S=120

# 应用运行日志（Python logging，按日轮转；默认 logs/app.log）
# APP_LOG_DIR=logs
# LOG_FILE_ENABLED=true
# LOG_BACKUP_DAYS=90
# LOG_LEVEL=INFO
# LOG_TO_CONSOLE=false

# 大纲任务心跳与判死（用于“继续未完成任务”与互斥）
# OUTLINE_HEARTBEAT_INTERVAL_S=180
# OUTLINE_JOB_STALE_AFTER_S=600
